# Email (Gmail SMTP) — used to notify the agency about new leads.
# EMAIL_HOST_PASSWORD is a Google "App password" (with or without spaces),
# not the account password. Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
LEADS_NOTIFY_EMAIL=
